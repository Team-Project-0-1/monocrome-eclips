{
  "name": "monochrome:-the-eclipse",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "optimize:assets": "node scripts/optimize-public-assets.mjs",
    "typecheck": "tsc --noEmit",
    "validate:passives": "node scripts/run-passive-validation.mjs",
    "check:release-assets": "node scripts/check-release-assets.mjs",
    "check:dist": "node scripts/check-dist-budget.mjs",
    "check:prototype-readiness": "node scripts/check-prototype-readiness.mjs",
    "security:audit": "npm audit --audit-level=moderate",
    "check": "npm run typecheck && npm run validate:passives && npm run check:release-assets && npm run build && npm run check:dist",
    "release:check": "npm run optimize:assets && npm run security:audit && npm run check",
    "prototype:check": "npm run release:check && npm run check:prototype-readiness",
    "build": "vite build && node scripts/prune-optimized-pngs.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "lucide-react": "^0.518.0",
    "zustand": "^5.0.6",
    "framer-motion": "^11.2.13",
    "immer": "^10.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
